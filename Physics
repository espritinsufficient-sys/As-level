<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>9702 A* Masterplan — Cambridge AS Physics</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #111118;
    --surface2: #16161f;
    --border: #1e1e2e;
    --accent: #c8a96e;
    --accent2: #7eb8c9;
    --accent3: #c97eb8;
    --red: #c97e7e;
    --green: #7ec9a0;
    --text: #e8e6df;
    --muted: #888899;
    --mono: 'IBM Plex Mono', monospace;
    --sans: 'IBM Plex Sans', sans-serif;
    --serif: 'Playfair Display', serif;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: var(–bg);
color: var(–text);
font-family: var(–sans);
font-size: 15px;
line-height: 1.7;
overflow-x: hidden;
}

/* ── HERO ── */
.hero {
position: relative;
padding: 80px 40px 60px;
border-bottom: 1px solid var(–border);
overflow: hidden;
}
.hero::before {
content: ‘’;
position: absolute;
inset: 0;
background:
radial-gradient(ellipse 60% 80% at 80% 20%, rgba(200,169,110,.08) 0%, transparent 60%),
radial-gradient(ellipse 40% 60% at 10% 90%, rgba(126,184,201,.06) 0%, transparent 55%);
pointer-events: none;
}
.hero-eyebrow {
font-family: var(–mono);
font-size: 11px;
letter-spacing: .2em;
color: var(–accent);
text-transform: uppercase;
margin-bottom: 16px;
}
.hero h1 {
font-family: var(–serif);
font-size: clamp(38px, 6vw, 72px);
line-height: 1.05;
color: var(–text);
max-width: 700px;
}
.hero h1 em {
color: var(–accent);
font-style: italic;
}
.hero-sub {
margin-top: 20px;
color: var(–muted);
font-size: 14px;
font-family: var(–mono);
max-width: 600px;
}
.exam-pills {
display: flex;
flex-wrap: wrap;
gap: 10px;
margin-top: 32px;
}
.pill {
display: inline-flex;
align-items: center;
gap: 8px;
padding: 8px 18px;
border-radius: 40px;
font-family: var(–mono);
font-size: 12px;
border: 1px solid;
animation: fadeUp .6s ease both;
}
.pill-p33 { border-color: var(–red); color: var(–red); background: rgba(201,126,126,.07); }
.pill-p22 { border-color: var(–accent); color: var(–accent); background: rgba(200,169,110,.07); }
.pill-p12 { border-color: var(–accent2); color: var(–accent2); background: rgba(126,184,201,.07); }
.pill-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; animation: pulse 2s ease infinite; }

/* ── NAV TABS ── */
.nav-tabs {
position: sticky;
top: 0;
z-index: 100;
background: rgba(10,10,15,.95);
backdrop-filter: blur(12px);
border-bottom: 1px solid var(–border);
display: flex;
overflow-x: auto;
padding: 0 24px;
gap: 0;
scrollbar-width: none;
}
.nav-tabs::-webkit-scrollbar { display: none; }
.tab-btn {
padding: 14px 20px;
font-family: var(–mono);
font-size: 11px;
letter-spacing: .1em;
text-transform: uppercase;
color: var(–muted);
background: none;
border: none;
border-bottom: 2px solid transparent;
cursor: pointer;
white-space: nowrap;
transition: all .2s;
}
.tab-btn:hover { color: var(–text); }
.tab-btn.active { color: var(–accent); border-bottom-color: var(–accent); }

/* ── SECTIONS ── */
.section { display: none; padding: 48px 40px 80px; max-width: 1100px; margin: 0 auto; }
.section.active { display: block; animation: fadeUp .4s ease; }

/* ── SECTION HEADERS ── */
.sec-header {
display: flex;
align-items: baseline;
gap: 16px;
margin-bottom: 40px;
padding-bottom: 16px;
border-bottom: 1px solid var(–border);
}
.sec-num {
font-family: var(–mono);
font-size: 11px;
color: var(–muted);
letter-spacing: .15em;
}
.sec-title {
font-family: var(–serif);
font-size: clamp(24px, 4vw, 40px);
color: var(–text);
}
.sec-badge {
margin-left: auto;
font-family: var(–mono);
font-size: 10px;
padding: 4px 10px;
border-radius: 4px;
}
.badge-urgent { background: rgba(201,126,126,.15); color: var(–red); border: 1px solid rgba(201,126,126,.3); }
.badge-theory { background: rgba(200,169,110,.15); color: var(–accent); border: 1px solid rgba(200,169,110,.3); }
.badge-mcq { background: rgba(126,184,201,.15); color: var(–accent2); border: 1px solid rgba(126,184,201,.3); }

/* ── CARDS ── */
.card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 8px;
padding: 24px 28px;
margin-bottom: 20px;
position: relative;
overflow: hidden;
}
.card::before {
content: ‘’;
position: absolute;
left: 0; top: 0; bottom: 0;
width: 3px;
}
.card-red::before { background: var(–red); }
.card-gold::before { background: var(–accent); }
.card-blue::before { background: var(–accent2); }
.card-purple::before { background: var(–accent3); }
.card-green::before { background: var(–green); }

.card-title {
font-family: var(–mono);
font-size: 11px;
letter-spacing: .15em;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 12px;
}
.card h3 {
font-family: var(–serif);
font-size: 20px;
color: var(–text);
margin-bottom: 10px;
}

/* ── CHECKLIST ── */
.checklist { list-style: none; }
.checklist li {
display: flex;
gap: 12px;
padding: 8px 0;
border-bottom: 1px solid rgba(255,255,255,.04);
font-size: 14px;
}
.checklist li:last-child { border-bottom: none; }
.check-icon {
flex-shrink: 0;
width: 20px;
height: 20px;
border-radius: 4px;
border: 1px solid var(–border);
display: flex;
align-items: center;
justify-content: center;
margin-top: 2px;
font-size: 11px;
color: var(–green);
background: rgba(126,201,160,.08);
border-color: rgba(126,201,160,.25);
}
.check-label { flex: 1; }
.check-label strong { color: var(–accent); }
.check-label code {
font-family: var(–mono);
font-size: 12px;
background: rgba(255,255,255,.06);
padding: 1px 6px;
border-radius: 3px;
color: var(–accent2);
}

/* ── RULE BOX ── */
.rule-box {
background: rgba(200,169,110,.06);
border: 1px solid rgba(200,169,110,.2);
border-radius: 6px;
padding: 16px 20px;
margin: 16px 0;
font-family: var(–mono);
font-size: 13px;
line-height: 1.8;
}
.rule-box .rule-title {
font-size: 10px;
letter-spacing: .2em;
text-transform: uppercase;
color: var(–accent);
margin-bottom: 8px;
}

/* ── TABLE ── */
.data-table {
width: 100%;
border-collapse: collapse;
font-size: 13px;
margin: 16px 0;
}
.data-table th {
font-family: var(–mono);
font-size: 10px;
letter-spacing: .15em;
text-transform: uppercase;
color: var(–muted);
padding: 10px 16px;
text-align: left;
border-bottom: 1px solid var(–border);
}
.data-table td {
padding: 12px 16px;
border-bottom: 1px solid rgba(255,255,255,.04);
vertical-align: top;
line-height: 1.6;
}
.data-table tr:last-child td { border-bottom: none; }
.data-table tr:hover td { background: rgba(255,255,255,.02); }
.td-num {
font-family: var(–mono);
font-size: 11px;
color: var(–accent);
width: 30px;
}
.td-limit { color: var(–red); font-weight: 500; }
.td-improve { color: var(–green); }

/* ── COMPARE BOXES ── */
.compare-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 16px;
margin: 16px 0;
}
@media(max-width:680px) { .compare-grid { grid-template-columns: 1fr; } }
.compare-bad {
background: rgba(201,126,126,.06);
border: 1px solid rgba(201,126,126,.25);
border-radius: 6px;
padding: 16px 18px;
}
.compare-good {
background: rgba(126,201,160,.06);
border: 1px solid rgba(126,201,160,.25);
border-radius: 6px;
padding: 16px 18px;
}
.compare-label {
font-family: var(–mono);
font-size: 10px;
letter-spacing: .2em;
text-transform: uppercase;
margin-bottom: 10px;
}
.compare-bad .compare-label { color: var(–red); }
.compare-good .compare-label { color: var(–green); }
.compare-text { font-size: 13px; line-height: 1.75; }
.compare-text mark {
background: rgba(200,169,110,.25);
color: var(–accent);
padding: 0 2px;
border-radius: 2px;
}
.compare-text del { color: var(–muted); opacity: .6; }

/* ── TRAP CARDS ── */
.trap-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
gap: 16px;
margin: 16px 0;
}
.trap-card {
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 8px;
padding: 20px;
position: relative;
}
.trap-card::after {
content: ‘⚠’;
position: absolute;
top: 14px;
right: 16px;
font-size: 16px;
opacity: .3;
}
.trap-title {
font-family: var(–mono);
font-size: 12px;
color: var(–red);
margin-bottom: 8px;
letter-spacing: .05em;
}
.trap-body { font-size: 13px; color: var(–muted); line-height: 1.7; }
.trap-body strong { color: var(–text); }
.trap-body code {
font-family: var(–mono);
font-size: 12px;
background: rgba(255,255,255,.06);
padding: 1px 5px;
border-radius: 3px;
color: var(–accent2);
}

/* ── FORECAST TABLE ── */
.forecast-item {
display: grid;
grid-template-columns: 200px 1fr auto;
gap: 16px;
align-items: center;
padding: 14px 0;
border-bottom: 1px solid rgba(255,255,255,.05);
}
@media(max-width:600px) { .forecast-item { grid-template-columns: 1fr; } }
.forecast-item:last-child { border-bottom: none; }
.forecast-topic { font-weight: 500; color: var(–text); }
.forecast-reason { font-size: 13px; color: var(–muted); }
.prob-bar-wrap { display: flex; align-items: center; gap: 8px; }
.prob-bar {
height: 6px;
border-radius: 3px;
min-width: 60px;
}
.prob-label { font-family: var(–mono); font-size: 11px; color: var(–accent); white-space: nowrap; }

/* ── CALENDAR ── */
.cal-grid {
display: flex;
flex-direction: column;
gap: 4px;
}
.cal-week {
display: grid;
grid-template-columns: 80px repeat(7, 1fr);
gap: 4px;
align-items: center;
}
.cal-week-label {
font-family: var(–mono);
font-size: 10px;
color: var(–muted);
letter-spacing: .1em;
text-transform: uppercase;
}
.cal-day {
aspect-ratio: 1;
border-radius: 6px;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
font-family: var(–mono);
font-size: 11px;
font-weight: 500;
border: 1px solid var(–border);
background: var(–surface2);
cursor: default;
transition: transform .15s;
padding: 4px;
min-height: 52px;
position: relative;
overflow: hidden;
}
.cal-day:hover { transform: scale(1.05); z-index: 2; }
.cal-day-num { font-size: 13px; }
.cal-day-label { font-size: 9px; letter-spacing: .05em; text-transform: uppercase; margin-top: 2px; opacity: .7; }
.cal-empty { background: transparent; border-color: transparent; }
.day-low { background: rgba(126,201,160,.07); border-color: rgba(126,201,160,.2); color: var(–green); }
.day-med { background: rgba(200,169,110,.08); border-color: rgba(200,169,110,.25); color: var(–accent); }
.day-high { background: rgba(201,126,126,.1); border-color: rgba(201,126,126,.3); color: var(–red); }
.day-exam {
background: rgba(201,126,126,.2);
border-color: var(–red);
color: #fff;
font-weight: 700;
box-shadow: 0 0 20px rgba(201,126,126,.3);
}
.day-exam::before {
content: ‘’;
position: absolute;
inset: 0;
background: repeating-linear-gradient(45deg, transparent, transparent 3px, rgba(255,255,255,.03) 3px, rgba(255,255,255,.03) 6px);
}
.day-exam-gold { border-color: var(–accent); background: rgba(200,169,110,.2); box-shadow: 0 0 20px rgba(200,169,110,.3); }
.day-exam-blue { border-color: var(–accent2); background: rgba(126,184,201,.2); box-shadow: 0 0 20px rgba(126,184,201,.3); }
.cal-legend {
display: flex;
gap: 16px;
flex-wrap: wrap;
margin-bottom: 24px;
font-family: var(–mono);
font-size: 11px;
}
.leg-item { display: flex; align-items: center; gap: 6px; }
.leg-swatch { width: 12px; height: 12px; border-radius: 3px; }
.week-plan {
margin-top: 12px;
padding: 12px 16px;
border-radius: 6px;
background: var(–surface2);
border: 1px solid var(–border);
font-size: 13px;
}
.week-plan-title {
font-family: var(–mono);
font-size: 10px;
letter-spacing: .15em;
text-transform: uppercase;
color: var(–accent);
margin-bottom: 6px;
}

/* ── REPEATER TAG ── */
.repeater-tag {
display: inline-block;
font-family: var(–mono);
font-size: 9px;
padding: 2px 7px;
border-radius: 3px;
margin-left: 8px;
background: rgba(201,126,126,.15);
color: var(–red);
border: 1px solid rgba(201,126,126,.3);
vertical-align: middle;
letter-spacing: .1em;
text-transform: uppercase;
}
.new-tag {
background: rgba(126,201,160,.12);
color: var(–green);
border-color: rgba(126,201,160,.3);
}

/* ── TOPIC PILL ROW ── */
.topic-row {
display: flex;
flex-wrap: wrap;
gap: 8px;
margin: 12px 0;
}
.topic-pill {
font-family: var(–mono);
font-size: 11px;
padding: 5px 12px;
border-radius: 20px;
border: 1px solid var(–border);
background: var(–surface2);
color: var(–muted);
}
.topic-pill.hot { border-color: rgba(201,126,126,.4); color: var(–red); background: rgba(201,126,126,.06); }
.topic-pill.warm { border-color: rgba(200,169,110,.4); color: var(–accent); background: rgba(200,169,110,.06); }
.topic-pill.cool { border-color: rgba(126,184,201,.4); color: var(–accent2); background: rgba(126,184,201,.06); }

/* ── DIVIDER ── */
.divider {
border: none;
border-top: 1px solid var(–border);
margin: 32px 0;
}

/* ── ANIMATIONS ── */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(16px); }
to { opacity: 1; transform: translateY(0); }
}
@keyframes pulse {
0%, 100% { opacity: 1; }
50% { opacity: .4; }
}

/* ── INLINE MATH ── */
.math {
font-family: var(–mono);
font-size: 13px;
background: rgba(255,255,255,.05);
padding: 1px 6px;
border-radius: 3px;
color: var(–accent2);
}

/* ── SCORE METER ── */
.score-row { display: flex; align-items: center; gap: 12px; margin: 8px 0; font-size: 13px; }
.score-label { width: 160px; color: var(–muted); flex-shrink: 0; }
.score-track { flex: 1; height: 4px; background: var(–border); border-radius: 2px; }
.score-fill { height: 100%; border-radius: 2px; transition: width .6s ease; }
.score-val { font-family: var(–mono); font-size: 11px; color: var(–accent); width: 30px; text-align: right; }

.info-block {
background: rgba(126,184,201,.05);
border: 1px solid rgba(126,184,201,.2);
border-radius: 6px;
padding: 14px 18px;
margin: 14px 0;
font-size: 13px;
color: var(–accent2);
font-family: var(–mono);
line-height: 1.8;
}
.warn-block {
background: rgba(201,126,126,.05);
border: 1px solid rgba(201,126,126,.2);
border-radius: 6px;
padding: 14px 18px;
margin: 14px 0;
font-size: 13px;
color: var(–red);
line-height: 1.7;
}

p { margin-bottom: 10px; font-size: 14px; }
h4 { color: var(–accent); font-family: var(–mono); font-size: 12px; letter-spacing: .1em; text-transform: uppercase; margin: 20px 0 8px; }
</style>

</head>
